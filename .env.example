PORT=4173
HOST=127.0.0.1
APEX_WEBHOOK_SECRET=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
EMBER_SCAN_SECRET=
CRON_SECRET=

# Optional generic source proxy
CALENDAR_CONNECTOR_URL=
LMS_CONNECTOR_URL=

# Optional Google Calendar connector
GOOGLE_CALENDAR_ID=
GOOGLE_CALENDAR_API_KEY=
GOOGLE_CALENDAR_BEARER_TOKEN=

# Optional Canvas LMS connector
