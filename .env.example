# Optional AI parser.
# If OPENAI_API_KEY is present, /api/ingest uses OpenAI after deterministic extraction.
# If APEX_AI_PARSE_URL is present, it is tried first as a provider-agnostic parser endpoint.
APEX_AI_PARSE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
